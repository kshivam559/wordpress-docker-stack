[mysqld]
# MEMORY USAGE
innodb_buffer_pool_size = 128M
innodb_log_file_size = 32M
innodb_log_buffer_size = 8M
innodb_buffer_pool_instances = 1

# CONNECTIONS
max_connections = 25
thread_cache_size = 4

# CACHE & PERFORMANCE
query_cache_type = 0
query_cache_size = 0
table_open_cache = 400
table_definition_cache = 400
key_buffer_size = 8M
tmp_table_size = 16M
max_heap_table_size = 16M

skip-name-resolve

# INNODB OPTIMIZATION
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT

# LOGGING
slow_query_log = 0
long_query_time = 2

# SECURITY
local_infile = 0